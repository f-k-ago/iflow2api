# ============================================
# OAuth 回调地址配置
# ============================================
# 如果部署在远程服务器，需要设置为公网地址
# 例如: https://your-domain.com 或 http://your-ip:28000
# 留空则使用 localhost（仅适用于本地部署）
# OAUTH_CALLBACK_BASE_URL=https://your-domain.com

# ============================================
# iFlow API 配置
# ============================================
# 方式1（推荐）：通过 Web UI 进行 OAuth 授权
#   访问 http://localhost:28000/admin 进行授权
#   配置会自动保存，无需手动填写下面的配置
#
# 方式2：手动配置 API Key
#   如果已有 API Key，可以直接填写下面的配置
# IFLOW_API_KEY=sk-your-api-key-here
# IFLOW_BASE_URL=https://apis.iflow.cn/v1

# ============================================
# 并发限制配置（官方规则：每个用户最多1个并发）
# ============================================
ENABLE_CONCURRENCY_LIMIT=true
MAX_CONCURRENT_REQUESTS=1

# ============================================
# 速率限制配置（单用户场景建议关闭）
# ============================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000